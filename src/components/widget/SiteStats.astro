---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;
const posts = await getSortedPosts();

function formatNumber(num: number): string {
	return num.toLocaleString();
}

function getBusuanziValueId(id?: string): string | undefined {
	if (id === "visitor-total") return "busuanzi_value_site_uv";
	if (id === "read-total") return "busuanzi_value_site_pv";
	return undefined;
}

function getBusuanziContainerId(id?: string): string | undefined {
	if (id === "visitor-total") return "busuanzi_container_site_uv";
	if (id === "read-total") return "busuanzi_container_site_pv";
	return undefined;
}

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
		formatted: true,
	},
	{
		icon: "material-symbols:person-outline",
		label: i18n(I18nKey.siteStatsVisitorCount),
		value: 0,
		dynamic: true,
		id: "visitor-total",
	},
	{
		icon: "material-symbols:visibility-outline",
		label: i18n(I18nKey.siteStatsReadCount),
		value: 0,
		dynamic: true,
		id: "read-total",
	},
];
---

<WidgetLayout name={i18n(I18nKey.siteStats)} id="site-stats" class={className} style={style}>
  <div class="flex flex-col gap-2">
    {stats.map((stat) => (
      <div class="flex items-center justify-between px-3 py-1.5">
        <div class="flex items-center gap-2.5">
          <div class="text-(--primary) text-xl">
            <Icon name={stat.icon} />
          </div>
          <span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm">
            {stat.label}
          </span>
        </div>
        <div class="flex items-center">
          <span id={getBusuanziContainerId(stat.id)} class="text-base font-bold text-neutral-900 dark:text-neutral-100">
            <span id={getBusuanziValueId(stat.id)}>
              {stat.formatted ? formatNumber(stat.value) : stat.value}
            </span>
          </span>
        </div>
      </div>
    ))}
  </div>
</WidgetLayout>

