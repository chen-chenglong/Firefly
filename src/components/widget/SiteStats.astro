---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { getSortedPosts } from "@/utils/content-utils";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;
const posts = await getSortedPosts();
const vercountApiUrl = siteConfig.vercount?.apiUrl ?? "https://events.vercount.one/js";

function formatNumber(num: number): string {
	return num.toLocaleString();
}

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
		formatted: true,
	},
	{
		icon: "material-symbols:person-outline",
		label: i18n(I18nKey.siteStatsVisitorCount),
		value: 0,
		dynamic: true,
		id: "visitor-total",
	},
	{
		icon: "material-symbols:visibility-outline",
		label: i18n(I18nKey.siteStatsReadCount),
		value: 0,
		dynamic: true,
		id: "read-total",
	},
];
---

<WidgetLayout name={i18n(I18nKey.siteStats)} id="site-stats" class={className} style={style}>
  <div class="flex flex-col gap-2">
    {stats.map((stat) => (
      <div class="flex items-center justify-between px-3 py-1.5">
        <div class="flex items-center gap-2.5">
          <div class="text-(--primary) text-xl">
            <Icon name={stat.icon} />
          </div>
          <span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm">
            {stat.label}
          </span>
        </div>
        <div class="flex items-center">
          <span
            class="text-base font-bold text-neutral-900 dark:text-neutral-100"
            data-stat-id={stat.id}
          >
            {stat.formatted ? formatNumber(stat.value) : stat.value}
          </span>
        </div>
      </div>
    ))}
  </div>
</WidgetLayout>

<script is:inline define:vars={{ vercountApiUrl }}>
  const vercountBaseUrl = vercountApiUrl.replace(/\/+$|^\s+|\s+$/g, "");

  function parseCountValue(data) {
    return Number(
      data?.visitorCount ??
        data?.visitors ??
        data?.visitorTotal ??
        data?.totalVisitors ??
        data?.readCount ??
        data?.readTotal ??
        data?.readingCount ??
        data?.views ??
        data?.pageViews ??
        data?.count ??
        0,
    );
  }

  async function fetchJson(url) {
    try {
      const response = await fetch(url, { cache: "no-store" });
      if (!response.ok) return null;
      return await response.json();
    } catch {
      return null;
    }
  }

  async function tryFetchVercountJson(urls) {
    for (const url of urls) {
      const json = await fetchJson(url);
      if (json && typeof json === "object") {
        return json;
      }
    }
    return null;
  }

  async function updateSiteStats() {
    const urls = [
      `${vercountBaseUrl}/api/site-stats`,
      `${vercountBaseUrl}/api/site`,
      `${vercountBaseUrl}/api/stats`,
      `${vercountBaseUrl}/api/counts`,
      `${vercountBaseUrl}/site`,
      `${vercountBaseUrl}/stats`,
    ];

    const data = await tryFetchVercountJson(urls);
    if (!data) return;

    const visitorTotal = Number(
      data.visitorCount ??
        data.visitors ??
        data.visitorTotal ??
        data.totalVisitors ??
        0,
    );
    const readTotal = Number(
      data.readCount ??
        data.readingCount ??
        data.readTotal ??
        data.views ??
        data.pageViews ??
        0,
    );

    if (visitorTotal > 0) {
      document.querySelectorAll("[data-stat-id='visitor-total']").forEach((element) => {
        element.textContent = new Intl.NumberFormat().format(visitorTotal);
      });
    }
    if (readTotal > 0) {
      document.querySelectorAll("[data-stat-id='read-total']").forEach((element) => {
        element.textContent = new Intl.NumberFormat().format(readTotal);
      });
    }
  }

  document.addEventListener("DOMContentLoaded", updateSiteStats);
  document.addEventListener("swup:contentReplaced", () => {
    setTimeout(updateSiteStats, 100);
  });
</script>
